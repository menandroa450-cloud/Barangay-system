generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  role         String
  firstName    String
  middleName   String?
  lastName     String
  age          Int?
  position     String?
  sex          String?
  phone        String?
  photo        String?
  scheduleTime String?  @default("08:00")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  records      AttendanceRecord[]
}

model AttendanceRecord {
  recordId  String   @id @default(cuid())
  userId    String
  role      String
  timeIn    DateTime
  timeOut   DateTime?
  dateKey   String   // e.g. "2026-02-10" in PH timezone
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
}

model Credential {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
